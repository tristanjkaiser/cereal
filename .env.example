# ============================================================================
# CEREAL - MCP Server for Granola Meeting Archives
# ============================================================================

# PostgreSQL database connection
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://localhost:5432/cereal

# Your company's email domain (for detecting external meeting attendees)
# Used by auto-client detection to distinguish internal vs external people
INTERNAL_DOMAIN=yourcompany.com

# Auto-archive settings (for scripts/auto_archive.py)
# Skip meetings newer than this (default: 2 hours)
# AUTO_ARCHIVE_SETTLE_HOURS=2
# Stop re-archiving meetings older than this (default: 3 hours)
# AUTO_ARCHIVE_FRESHNESS_HOURS=3
